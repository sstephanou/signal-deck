# Normalize line endings to LF in the repository.
# Git will convert to CRLF on checkout on Windows if core.autocrlf=true,
# but the stored copy in the repo is always LF.

* text=auto eol=lf

# Explicit overrides
*.py    text eol=lf
*.ts    text eol=lf
*.tsx   text eol=lf
*.js    text eol=lf
*.json  text eol=lf
*.md    text eol=lf
*.toml  text eol=lf
*.css   text eol=lf
*.html  text eol=lf
*.sh    text eol=lf

# Binary files
*.png   binary
*.jpg   binary
*.ico   binary
*.woff2 binary
